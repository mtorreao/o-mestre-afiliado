# ═══════════════════════════════════════════════════════════════
# MERCADO LIVRE — Credenciais de Afiliados
# ═══════════════════════════════════════════════════════════════
#
# Escolha uma das 3 estratégias abaixo:

# ── ESTRATÉGIA 1: API OFICIAL OAuth 2.0 (RECOMENDADO) ──────
# Registre sua app em: https://developers.mercadolivre.com.br/
# App registrada: "O Mestre Afiliado" (App ID: 8762086145951776)
# Redirect URI configurada: https://omestreafiliado.com.br/
# ML_CLIENT_ID=seu_client_id
# ML_CLIENT_SECRET=seu_client_secret
# ML_REFRESH_TOKEN=seu_refresh_token

# ── ESTRATÉGIA 2: COOKIES (Link Builder simulado) ───────────
# Obtenha os cookies da sessão logada em mercadolivre.com.br
# ML_COOKIES="session_id=xxx; CSRF_TOKEN=xxx; ..."


# ═══════════════════════════════════════════════════════════════
# SHOPEE — Credenciais do Programa de Afiliados
# ═══════════════════════════════════════════════════════════════
SHOPEE_APP_ID=seu_app_id_aqui
SHOPEE_SECRET=seu_app_secret_aqui

# ═══════════════════════════════════════════════════════════════
# AMAZON — Associates (futuro)
# ═══════════════════════════════════════════════════════════════
# AMAZON_TRACKING_ID=meusite-20


# ═══════════════════════════════════════════════════════════════
# EVOLUTION API — Infraestrutura (docker-compose.infra.yml)
# ═══════════════════════════════════════════════════════════════
#
# Essas variáveis são usadas pelo docker-compose.infra.yml
# Para usar, crie um .env.infra na raiz com os valores reais
# (veja .env.infra para template completo)
#
# EVOLUTION_API_KEY=
# EVOLUTION_API_URL=http://localhost:5444
# EVOLUTION_WEBHOOK_URL=
#
# POSTGRES_DATABASE=omestre_db        # Banco compartilhado
# POSTGRES_USERNAME=evolution
# POSTGRES_PASSWORD=
# POSTGRES_PORT=127.0.0.1:5443:5432     # 5443 no host → 5432 no container
#
#
# ═══════════════════════════════════════════════════════════════
# REVALIDAÇÃO PERIÓDICA — Worker de validação de grupos
# ═══════════════════════════════════════════════════════════════
# Define de quantos em quantos dias os grupos fonte são revalidados.
# Um grupo que antes passava (≥70%) e cair abaixo do threshold
# dispara um alerta nos logs do worker.
# REVALIDATION_INTERVAL_DAYS=7

# ═══════════════════════════════════════════════════════════════
# WORKER — Métricas de saúde
# ═══════════════════════════════════════════════════════════════
# URL para a API interna de métricas do worker.
# Dentro do Docker Compose, a API container usa http://worker:9092.
# O default em apps/api/src/index.ts é http://localhost:9092 (host dev).
# WORKER_METRICS_URL=http://worker:9092

# ═══════════════════════════════════════════════════════════════
# SEGURANÇA — Criptografia e autenticação
# ═══════════════════════════════════════════════════════════════
# Chave AES-256-GCM para criptografar sessionCookies em ml_affiliates.
# Gere com: openssl rand -hex 32
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Chave de API para autenticar requisições ao servidor de métricas do worker.
# Se não configurada, o servidor de métricas fica aberto (compat retroativa).
# METRICS_API_KEY=
