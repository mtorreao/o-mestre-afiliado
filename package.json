{
  "name": "o-mestre-afiliado",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:worker": "bun run --cwd apps/worker dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build:api": "bun run --cwd apps/api build",
    "build:worker": "bun run --cwd apps/worker build",
    "build:web": "bun run --cwd apps/web build",
    "build": "bun build:api && bun build:worker && bun build:web",
    "shopee": "bun run --cwd packages/converters shopee",
    "mercadolivre": "bun run --cwd packages/converters mercadolivre",
    "ml": "bun run --cwd packages/converters mercadolivre",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "seed:ml": "bun run --cwd apps/api seed:ml",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "typescript": "^5"
  }
}
