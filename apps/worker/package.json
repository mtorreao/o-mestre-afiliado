{
  "name": "@omestre/worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "revalidate": "bun run --hot src/index.ts --revalidate",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omestre/converters": "workspace:*",
    "@omestre/shared": "workspace:*",
    "@omestre/db": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
