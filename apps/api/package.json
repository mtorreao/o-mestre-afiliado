{
  "name": "@omestre/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:ml": "bun run src/seed-ml.ts"
  },
  "dependencies": {
    "@omestre/converters": "workspace:*",
    "@omestre/db": "workspace:*",
    "@omestre/shared": "workspace:*",
    "elysia": "^1.2.25",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
